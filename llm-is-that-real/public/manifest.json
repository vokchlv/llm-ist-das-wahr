{
  "manifest_version": 3,
  "name": "Ist das wahr?",
  "version": "1.0.0",
  "description": "AI-powered fact-checking for the entire web",
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ist das wahr?"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
